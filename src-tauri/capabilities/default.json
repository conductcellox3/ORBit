{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-open-path",
    "opener:allow-reveal-item-in-dir",
    "fs:default",
    "fs:allow-appdata-read",
    "fs:allow-appdata-write",
    "fs:allow-applocaldata-read",
    "fs:allow-applocaldata-write",
    "fs:allow-exe-read",
    "fs:allow-exe-write",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-read-text-file",
    "fs:allow-read-dir",
    "fs:allow-write-text-file",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$EXEDIR/**"
        },
        {
          "path": "$EXE/**"
        },
        {
          "path": "$RESOURCE/**"
        },
        {
          "path": "$APPLOCALDATA/**"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$HOME/**"
        },
        {
          "path": "$DESKTOP/**"
        },
        {
          "path": "$DOCUMENT/**"
        },
        {
          "path": "$DOWNLOAD/**"
        },
        {
          "path": "D:/Antigravity/ORBit/BoardSample/workspace/**"
        },
        {
          "path": "D:/Antigravity/ORBit/src-tauri/target/debug/**"
        }
      ]
    },
    "clipboard-manager:default",
    "dialog:default"
  ]
}